APP_ENV=docker
# JWT authentication (Phase 2+)
# Change JWT_SECRET_KEY to a random 32+ byte value before deploying.
# Default is intentionally weak — suitable only for local development.
JWT_SECRET_KEY=anpr-default-secret-change-me
JWT_EXPIRATION_MINUTES=480

# Legacy API key fallback (backward compatibility).
# If set, the static key is accepted alongside JWT tokens.
# Clients may send  X-Api-Key: <key>  or  ?api_key=<key>  (for SSE / MJPEG streams).
# Leave empty (default) to use JWT-only authentication.
# Will be removed in a future hardening phase.
API_KEY=
DEBUG=false
LOG_LEVEL=INFO
SETTINGS_PATH=/app/config/settings.yaml
HTTP_PORT=8080
POSTGRES_DB=anpr
POSTGRES_USER=anpr
POSTGRES_PASSWORD=anpr
POSTGRES_DSN=postgresql://anpr:anpr@postgres:5432/anpr
# Thread limits for PyTorch/OpenMP/MKL (prevents CPU oversubscription with multiple channels)
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2
OPENBLAS_NUM_THREADS=2
