APP_ENV=docker
# Set a non-empty value to enable API key authentication on all /api/* routes.
# Clients must send  X-Api-Key: <key>  or  Authorization: Bearer <key>.
# For SSE / MJPEG streams append  ?api_key=<key>  to the URL.
# Leave empty to disable authentication (suitable for trusted LAN deployments).
API_KEY=
DEBUG=false
LOG_LEVEL=INFO
SETTINGS_PATH=/app/config/settings.yaml
HTTP_PORT=8080
POSTGRES_DB=anpr
POSTGRES_USER=anpr
POSTGRES_PASSWORD=anpr
POSTGRES_DSN=postgresql://anpr:anpr@postgres:5432/anpr
